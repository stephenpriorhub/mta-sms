# --- Database (Railway Postgres) ---
DATABASE_URL="postgresql://user:pass@host:5432/railway"

# --- OxfordHub SSO (admin surface only) ---
# The hub Project.id (cuid) registered for this app. Used as data-project-id for
# hub-nav.js AND as ?projectId= when forwarding cookies to the hub /api/me.
NEXT_PUBLIC_HUB_PROJECT_ID="REPLACE_WITH_HUB_PROJECT_ID"
# Base URL of the hub (override only for local testing).
HUB_URL="https://oxfordhub.app"
# Shared service token for server-to-server / maintenance calls (admin-equivalent).
HUB_API_TOKEN="REPLACE_WITH_SHARED_HUB_API_TOKEN"
